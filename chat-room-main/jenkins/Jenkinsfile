pipeline {
    agent any

    tools {
        maven 'MAVEN_HOME'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Debug') {
            steps {
                sh 'ls -R'
            }
        }

        stage('Backend Build') {
            steps {
                dir('chat-room-main/backend') {
                    sh 'mvn clean package -DskipTests'
                }
            }
        }

        stage('Frontend Build') {
            steps {
                dir('chat-room-main/front-chat') {
                    sh 'npm install'
                    sh 'npm run build'
                }
            }
        }

       stage('Docker Build') {
                   steps {
                       dir('chat-room-main') {
                           sh 'docker compose build'
                       }
                   }
               }

               stage('Deploy') {
                   steps {
                       dir('chat-room-main') {
                           sh 'docker compose up -d'
                       }
                   }
               }
    }
}